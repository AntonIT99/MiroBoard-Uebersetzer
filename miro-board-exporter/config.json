{
  "cdp_url": "http://127.0.0.1:9222",
  "output_root": "miro-export",
  "ask_resolution_each_run": true,
  "default_max_tiles": 120,
  "target_zoom_percent": 100,
  "overlap_px": 160,
  "render_wait_ms": 700,
  "navigation": {
    "auto_calibrate_pan": true,
    "calibration_fraction": 0.22,
    "pan_scale_fallback_x": 0.42,
    "pan_scale_fallback_y": 0.42,
    "pan_scale_min": 0.1,
    "pan_scale_max": 1.5,
    "step_fraction_x": 0.48,
    "step_fraction_y": 0.48,
    "precise_navigation": true,
    "movement_tolerance_px": 18,
    "max_correction_attempts": 1,
    "max_measured_step_fraction": 0.5,
    "command_safety_factor": 0.94,
    "measurement_wait_ms": 180,
    "adaptive_scale": true,
    "reanchor_each_occupied_row": true,
    "open_loop_for_grid_moves": true
  },
  "bounds": {
    "detect_from_fit_overview": true,
    "background_difference_threshold": 16,
    "fit_padding_px": 3,
    "first_tile_margin_px": 60,
    "right_bottom_margin_px": 48,
    "occupancy_skip_enabled": true,
    "occupancy_padding_fit_px": 12,
    "save_fit_overview": true,
    "alignment_correction_attempts": 3,
    "alignment_tolerance_px": 10,
    "anchor_search_enabled": true,
    "anchor_search_step_fraction_x": 0.3,
    "anchor_search_step_fraction_y": 0.3,
    "anchor_search_max_steps_x": 3,
    "anchor_search_max_steps_y": 10,
    "save_anchor_debug": true
  },
  "capture": {
    "fast_mode": true,
    "post_move_wait_ms": 25,
    "content_capture_wait_ms": 25,
    "probe_jpeg_quality": 28,
    "save_blank_tiles": false,
    "stability_interval_ms": 500,
    "stability_max_wait_ms": 4000,
    "stability_required_matches": 1,
    "stability_difference_threshold": 2.0,
    "blank_retry_count": 0,
    "blank_retry_wait_ms": 0
  },
  "blank_filter": {
    "enabled": true,
    "move_blank_tiles_to_subfolder": false,
    "blank_subfolder": "_blank_tiles",
    "blur_radius": 1.5,
    "difference_threshold": 16,
    "minimum_content_fraction": 0.00035,
    "minimum_contrast_stddev": 0.8
  },
  "coverage_safety_factor": 1.0,
  "crop": {
    "left": 90,
    "top": 65,
    "right": 30,
    "bottom": 85
  },
  "create_preview": true,
  "preview_scale": 0.12,
  "max_tiles_without_extra_confirmation": 300,
  "create_pdf": true,
  "pdf_filename": "miro-board-export.pdf",
  "pdf_include_blank_tiles": false,
  "pdf_image_format": "jpeg",
  "pdf_jpeg_quality": 85,
  "pdf_image_scale": 1.0,
  "absolute_navigation": {
    "enabled": true,
    "calibrate_scale": true,
    "calibration_drag_fraction": 0.3,
    "calibration_probe_width": 1800,
    "fit_reset_wait_ms": 260,
    "zoom_step_wait_ms": 140,
    "post_zoom_wait_ms": 120,
    "save_tile_plan": true,
    "center_content_before_scale_calibration": true,
    "prefer_horizontal_scale": true,
    "minimum_overlap_fraction_x": 0.65,
    "minimum_overlap_fraction_y": 0.65
  }
}
